# Backend configuration (do not commit real secrets; copy to .env in deployment environment)

# REQUIRED: Secret used to sign JWT access tokens.
# Generate a strong random value (32+ bytes).
JWT_SECRET=change_me_to_a_long_random_secret

# OPTIONAL: JWT algorithm (defaults to HS256)
JWT_ALGORITHM=HS256

# OPTIONAL: Access token TTL in minutes (defaults to 10080 = 7 days)
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=10080

# OPTIONAL: SQLite DB path (defaults to ./data/app.db relative to container root)
DATABASE_URL=sqlite:///./data/app.db

# OPTIONAL: CORS origins (comma-separated). If unset, "*" is used for dev.
CORS_ALLOW_ORIGINS=http://localhost:3000,https://example.com
